# Environment Variables for Lead Capture System

# WhatsApp Notification Settings
# Choose your provider: "twilio", "wati", or "interakt"
WHATSAPP_PROVIDER=twilio
WHATSAPP_NOTIFICATION_NUMBER=919885851127

# === TWILIO Configuration ===
# Get these from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
# WhatsApp-enabled Twilio number (format: whatsapp:+14155238886)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# === WATI Configuration ===
# Get these from: https://app.wati.io/
# WATI_API_KEY=your_wati_api_key_here
# WATI_API_URL=https://live-server-XXXXX.wati.io

# === Interakt Configuration ===
# Get these from: https://app.interakt.ai/
# INTERAKT_API_KEY=your_interakt_api_key_here

# Database (MongoDB)
MONGODB_URI=your_mongodb_connection_string_here
